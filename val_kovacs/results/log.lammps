# ── 4. EQUILIBRATE AT T=0.4 (reach true equilibrium) ─────────────────────────
# Run long enough that PE flatlines — this is PE_ref.
# 150000 steps matches the Kovacs measurement window so ΔPE(t) is directly
# comparable step-by-step.
fix             3 all nvt temp 0.4 0.4 0.1

variable        ref_pe equal pe
fix             ref_out all print 100 "${ref_pe}" file reference_thermo.txt screen no

# Dump structural snapshots at matching frames for GNN comparison
# Frames saved every 1000 steps = 201 total frames (matches dump.kovacs)
dump            1 all custom 1000 dump.reference id type x y z
dump_modify     1 sort id

thermo          1000
run             200000
