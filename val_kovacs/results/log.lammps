package gpu 1
# ============================================================================
# LAMMPS Reference Trajectory — Kovacs Memory Effect Baseline
# PURPOSE: Generate a glass equilibrated DIRECTLY at T=0.4 (no quench path).
#          This produces PE_ref, the equilibrium baseline at T=0.4.
#          The Kovacs signal = PE_kovacs(t) - PE_ref  (should be non-monotonic)
# RUN AS:  lmp -sf gpu -pk gpu 1 -in kovacs_reference.in
# ============================================================================

units           lj
dimension       3
boundary        p p p
atom_style      atomic

# ── 1. IDENTICAL SYSTEM SETUP (must match kovacs_memory.in exactly) ──────────
region          box block 0 20.274 0 20.274 0 20.274
create_box      2 box
Created orthogonal box = (0 0 0) to (20.274 20.274 20.274)
  2 by 2 by 2 MPI processor grid
create_atoms    1 random 8000 12345 box          # SAME seeds as original
Created 8000 atoms
  using lattice units in orthogonal box = (0 0 0) to (20.274 20.274 20.274)
  create_atoms CPU = 0.001 seconds
create_atoms    2 random 2000 54321 box
Created 2000 atoms
  using lattice units in orthogonal box = (0 0 0) to (20.274 20.274 20.274)
  create_atoms CPU = 0.000 seconds

mass            1 1.0
mass            2 1.0
pair_style      lj/cut 2.5
pair_coeff      1 1 1.0 1.0
pair_coeff      1 2 1.5 0.8
pair_coeff      2 2 0.5 0.88

thermo          100
minimize        1.0e-4 1.0e-6 1000 10000

